# ─── Contact Form Email Pipeline ───────────────────────────────
# Required: Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=

# Required: Sender email address (must be from a verified domain in Resend)
# For Resend sandbox testing: onboarding@resend.dev
# For production: your-verified-domain sender, e.g. noreply@sp-net.in
CONTACT_FROM=

# Required: Recipient email address (where form submissions are delivered)
CONTACT_EMAIL=savan@sp-net.in

# ─── Rate Limiting (Upstash Redis) ─────────────────────────────
# Required: Upstash Redis REST URL (get from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=

# Required: Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=

# Optional: Rate limit configuration (defaults shown)
# Maximum requests allowed per window per IP
RATE_LIMIT_MAX=5

# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
