# ─── Contact Form Email Pipeline ───────────────────────────────
# HOW TO SET UP:
#   1. Create a free account at https://resend.com
#   2. Go to https://resend.com/api-keys and create an API key
#   3. Copy the key into RESEND_API_KEY below
#   4. For testing: leave CONTACT_FROM as-is (uses Resend sandbox)
#   5. For production: verify your domain at https://resend.com/domains
#      then set CONTACT_FROM to a sender on that domain
#
# QUICK TEST:
#   cp .env.example .env.local   # if .env.local doesn't exist
#   # fill in RESEND_API_KEY
#   npx tsx scripts/test-email.ts --check   # verify env vars
#   npx tsx scripts/test-email.ts           # send test email

# Required: Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=

# Required: Sender email address (must be from a verified domain in Resend)
# For Resend sandbox testing: use any address on @resend.dev (e.g. onboarding@resend.dev)
# For production: your verified domain sender, e.g. noreply@sp-net.in
CONTACT_FROM=

# Required: Recipient email address (where form submissions are delivered)
CONTACT_EMAIL=savan@sp-net.in

# ─── Diagnostics Email Pipeline ────────────────────────────────
# Optional: Diagnostics sender email address
# Must be from a verified domain in Resend
DIAGNOSTICS_EMAIL_FROM=

# Optional: Diagnostics recipient email address
# Where error reports are delivered
DIAGNOSTICS_EMAIL_TO=savan@sp-net.in

# ─── Rate Limiting (Upstash Redis) ─────────────────────────────
# Optional: Upstash Redis REST URL (get from https://console.upstash.com)
# Without this, rate limiting is silently skipped
UPSTASH_REDIS_REST_URL=

# Optional: Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=

# Optional: Rate limit configuration (defaults shown)
# Maximum requests allowed per window per IP
RATE_LIMIT_MAX=5

# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
